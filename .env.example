# Hybrid LLM Safety System - Environment Variables Example
# Copy this file to .env and configure your secrets

# Authentication
SAFETY_AUTH_API_KEYS=key1,key2,key3

# Rate Limits (Optional, overrides yaml)
SAFETY_RATE_LIMITS_CLASSIFY_IP=10/minute
SAFETY_RATE_LIMITS_CLASSIFY_API_KEY=100/minute

# Other configurations (Optional, overrides yaml)
SAFETY_LOGGING_DEBUG_MODE=false
